# Dependencies
# /vendor/ is intentionally committed so the repo can be used directly as a WordPress plugin without running `composer install`.
# Exclude bundled tests, fixtures, and dev metadata that ship inside vendor packages — they bloat the repo and aren't needed at runtime.
/vendor/**/test/
/vendor/**/tests/
/vendor/**/Test/
/vendor/**/Tests/
/vendor/**/.git*
/vendor/**/.travis.yml
/vendor/**/.styleci.yml
/vendor/**/.php_cs
/vendor/**/.php_cs.dist
/vendor/**/phpunit.xml*
/vendor/**/phpcs.xml*
/vendor/**/CONTRIBUTING.md
/vendor/**/CHANGELOG.md
/node_modules/

# Development files
.claude/
*.claude

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*.local

# Build files
/build/
/dist/

# Temporary files
*.tmp
*.temp
*.cache
.sass-cache/

# WordPress specific
wp-config.php
/wp-content/uploads/
/wp-content/upgrade/
/wp-content/backup-db/
/wp-content/cache/
/wp-content/backups/
